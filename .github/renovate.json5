{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigestsToSemver',
    'docker:pinDigests',
    ':maintainLockFilesWeekly',
  ],
  schedule: [
    'on monday',
  ],
  enabledManagers: [
    'github-actions',
    'cargo',
    'git-submodules',
    'dockerfile',
    'pre-commit',
    'rust-toolchain',
  ],
  'git-submodules': {
    enabled: true,
  },
  osvVulnerabilityAlerts: true,
  labels: [
    'dependencies',
  ],
  packageRules: [
    {
      matchManagers: [
        'github-actions',
      ],
      groupName: 'GitHub Actions',
      addLabels: [
        'github-actions',
      ],
    },
    {
      matchManagers: [
        'cargo',
      ],
      groupName: 'Rust dependencies',
      addLabels: [
        'rust',
      ],
    },
    {
      matchManagers: [
        'git-submodules',
      ],
      groupName: 'Git submodules',
      addLabels: [
        'submodule',
      ],
    },
    {
      matchManagers: [
        'dockerfile',
      ],
      groupName: 'Docker images',
      addLabels: [
        'docker',
      ],
    },
    {
      matchManagers: [
        'pre-commit',
      ],
      groupName: 'pre-commit hooks',
      addLabels: [
        'pre-commit',
      ],
    },
    {
      matchManagers: [
        'rust-toolchain',
      ],
      groupName: 'Rust toolchain',
      addLabels: [
        'rust',
      ],
    },
  ],
  prHourlyLimit: 4,
  prConcurrentLimit: 16,
}
